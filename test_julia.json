{
  "ActionList": {
    "solve": {
      "FunctionName": "solveSIRModel",
      "FaaSServer": "GH",
      "InvokeNext": [
        "processData"
      ],
      "Type": "Julia"
    },
    "getData": {
      "FunctionName": "getSIRData",
      "FaaSServer": "GH",
      "InvokeNext": [
        "solve"
      ],
      "Type": "Python"
    },
    "processData": {
      "FunctionName": "processSIRData",
      "FaaSServer": "GH",
      "InvokeNext": [],
      "Type": "R"
    }
  },
  "ComputeServers": {
    "GH": {
      "FaaSType": "GitHubActions",
      "UseSecretStore": true,
      "ActionRepoName": "FaaSr-workflow-public",
      "Branch": "main",
      "UserName": "Ashish-Ramrakhiani"
    }
  },
  "DataStores": {
    "My_S3_Bucket": {
            "Endpoint": "https://s3.us-west-2.amazonaws.com",
            "Bucket": "faasr-bucket-0001",
            "Region": "us-west-2",
            "Writable": "TRUE"
        }
  },
  "ActionContainers": {
    "solve": "izzylerman/faasr-githubactions-julia-sir",
    "getData": "izzylerman/faasr-github-actions-python:latest",
    "processData": "izzylerman/faasr-github-actions-r:latest"
  },
  "FunctionInvoke": "getData",
  "DefaultDataStore": "MY_S3_Bucket",
  "FunctionGitRepo": {
    "solveSIRModel": "IzzyLerman/SIRWorkflow",
    "getSIRData": "IzzyLerman/SIRWorkflow",
    "processSIRData": "IzzyLerman/SIRWorkflow"
  },
  "FaaSrLog": "FaaSrLog",
  "LoggingDataStore": "MY_S3_Bucket",
  "WorkflowName": "SIRModelWorkflow",
  "PyPIPackageDownloads": {
    "getSIRData": [
      "numpy",
      "pandas",
      "math"
    ]
  }
}
