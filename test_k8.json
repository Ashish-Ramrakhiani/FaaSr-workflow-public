{
    "ComputeServers": {
        "GH": {
            "FaaSType": "GitHubActions",
            "UseSecretStore": true,
            "UserName": "Ashish-Ramrakhiani",
            "ActionRepoName": "FaaSr-workflow-public",
            "Branch": "main"
        },
        "MyK8sCluster": {
            "FaaSType": "Kubernetes",
            "Endpoint": "https://129.146.139.205:6443",
            "Namespace": "faasr-jobs",
            "UseSecretStore": false
        }
    },
    "DataStores": {
        "My_S3_Bucket": {
            "Endpoint": "https://s3.us-west-2.amazonaws.com",
            "Bucket": "faasr-bucket-0001",
            "Region": "us-west-2",
            "Writable": "true"
        }
    },
    "ActionList": {
        "start": {
            "FunctionName": "timestamp_logger",
            "FaaSServer": "GH",
            "Type": "Python",
            "Arguments": {
                "folder": "runtime_test",
                "tag": "start"
            },
            "InvokeNext": ["action-k8s-1", "action-k8s-2", "action-gh"]
        },
        "action-k8s-1": {
            "FunctionName": "timestamp_logger",
            "FaaSServer": "MyK8sCluster",
            "Type": "Python",
            "Arguments": {
                "folder": "runtime_test",
                "tag": "k8s-1"
            },
            "InvokeNext": []
        },
        "action-k8s-2": {
            "FunctionName": "timestamp_logger",
            "FaaSServer": "MyK8sCluster",
            "Type": "Python",
            "Arguments": {
                "folder": "runtime_test",
                "tag": "k8s-2"
            },
            "InvokeNext": []
        },
        "action-gh": {
            "FunctionName": "timestamp_logger",
            "FaaSServer": "GH",
            "Type": "Python",
            "Arguments": {
                "folder": "runtime_test",
                "tag": "gh"
            },
            "InvokeNext": []
        }
    },
    "ActionContainers": {
        "start": "faasr/kubernetes-python:latest",
        "action-k8s-1": "faasr/kubernetes-python:latest",
        "action-k8s-2": "faasr/kubernetes-python:latest",
        "action-gh": "faasr/kubernetes-python:latest"
    },
    "FunctionGitRepo": {
        "timestamp_logger": "Ashish-Ramrakhiani/FaaSr-workflow-public"
    },
    "FunctionInvoke": "start",
    "FaaSrLog": "FaaSrLog",
    "LoggingDataStore": "My_S3_Bucket",
    "DefaultDataStore": "My_S3_Bucket",
    "InvocationIDFromDate": "%Y%m%d%H%M",
    "WorkflowName": "k8s-benchmark"
