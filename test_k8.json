{
    "ComputeServers": {
        "GH": {
            "FaaSType": "GitHubActions",
            "UseSecretStore": true,
            "UserName": "Ashish-Ramrakhiani",
            "ActionRepoName": "FaaSr-workflow-public",
            "Branch": "main"
        },
        "MyK8sCluster": {
            "FaaSType": "Kubernetes",
            "Endpoint": "https://129.146.139.205:6443",
            "Namespace": "faasr-jobs",
            "UseSecretStore": false
        }
    },
    "DataStores": {
        "My_S3_Bucket": {
            "Endpoint": "https://s3.us-west-2.amazonaws.com",
            "Bucket": "faasr-bucket-0001",
            "Region": "us-west-2",
            "Writable": "true"
        }
    },
    "ActionList": {
        "start": {
            "FunctionName": "r_log",
            "FaaSServer": "GH",
            "Type": "R",
            "Arguments": {
                "message": "Starting from GH"
            },
            "InvokeNext": ["action-k8s-1", "action-k8s-2", "action-gh"]
        },
        "action-k8s-1": {
            "FunctionName": "r_log",
            "FaaSServer": "MyK8sCluster",
            "Type": "R",
            "Arguments": {
                "message": "Hello from Kubernetes job 1"
            },
            "InvokeNext": []
        },
        "action-k8s-2": {
            "FunctionName": "r_log",
            "FaaSServer": "MyK8sCluster",
            "Type": "R",
            "Arguments": {
                "message": "Hello from Kubernetes job 2"
            },
            "InvokeNext": []
        },
        "action-gh": {
            "FunctionName": "r_log",
            "FaaSServer": "GH",
            "Type": "R",
            "Arguments": {
                "message": "Hello from GitHub Actions"
            },
            "InvokeNext": []
        }
    },
    "ActionContainers": {
        "start": "ghcr.io/ashish-ramrakhiani/github-actions-r:2.0",
        "action-k8s-1": "ramrakha/kubernetes-r:test",
        "action-k8s-2": "ramrakha/kubernetes-r:test",
        "action-gh": "ghcr.io/ashish-ramrakhiani/github-actions-r:2.0"
    },
    "FunctionGitRepo": {
        "r_log": "Ashish-Ramrakhiani/test-py"
    },
    "FunctionInvoke": "start",
    "FaaSrLog": "FaaSrLog",
    "LoggingDataStore": "My_S3_Bucket",
    "DefaultDataStore": "My_S3_Bucket",
    "InvocationIDFromDate": "%Y%m%d%H%M",
    "WorkflowName": "k8s-benchmark"
}
